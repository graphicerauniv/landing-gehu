---
import Document from "../layouts/Document.astro";
import Landing from "../layouts/Landing.astro";

import Hero from "../components/shared/Hero.tsx";
import Courses from "../components/shared/Courses.tsx";
import AdmissionProcess from "../components/shared/AdmissionProcess.tsx";
import Banner from "../components/shared/Banner.tsx";
import PlacementStats from "../components/shared/PlacementStats.tsx";
import Faq from "../components/shared/Faq.tsx";
import KeyHighlights from "../components/shared/KeyHighlights";
import ScholarshipHighlights from "../components/shared/ScholarshipHighlights.astro";
import CampusesHighlight from "../components/shared/CampusesHighlight.tsx";

import { apply as course } from "../data/courses.ts";
---

<Document title={course.meta.title} description={course.meta.description}>
    <Landing>
        <Hero campaignSource="GENERIC-HILL" client:load />
        <script is:inline type="text/javascript">
            var s = document.createElement("script");
            s.type = "text/javascript";
            s.async = true;
            s.src = "https://widgets.in4.nopaperforms.com/emwgts.js";
            document.body.appendChild(s);
        </script>

        <Courses client:load />

        <ScholarshipHighlights />

        <CampusesHighlight client:load />

        <AdmissionProcess />

        <Banner client:load />

        <KeyHighlights client:idle />

        <PlacementStats client:load />

        <Faq faqs={course.faqs} client:load />
    </Landing>
</Document>
