---
import Document from "../layouts/Document.astro";
import Landing from "../layouts/Landing.astro";

import CheckCircleIcon from "../assets/icons/check-circle.svg";
import geuWhite from "../assets/geu-white.svg";
---

<Document
    title="Thank You - GEU Admissions"
    description="Thank you for your application to Graphic Era University"
>
    <Landing>
        <div
            class="min-h-screen bg-[linear-gradient(135deg,rgba(0,0,0,0.2),rgba(0,0,0,0.4),rgba(0,0,0,0.6)),url('/lp/bg.webp')] bg-cover bg-center bg-no-repeat"
        >
            <!-- Header -->
            <div
                class="flex max-w-6xl flex-col items-center justify-between px-4 py-8 pt-20 text-white sm:mx-auto sm:flex-row sm:px-2"
            >
                <img
                    src={geuWhite.src}
                    alt="GEU Logo"
                    class="w-48 drop-shadow-lg sm:w-60"
                />
            </div>

            <!-- Main Content -->
            <div
                class="flex min-h-[calc(100vh-200px)] max-w-6xl items-center justify-center px-4 py-12 sm:mx-auto sm:px-2"
            >
                <div class="w-full max-w-3xl">
                    <!-- Success Card -->
                    <div
                        class="group hover:shadow-3xl relative overflow-hidden rounded-3xl border border-white/20 bg-white/10 shadow-2xl backdrop-blur-xl transition-all duration-500 hover:scale-[1.02]"
                    >
                        <!-- Gradient Overlay -->
                        <div
                            class="pointer-events-none absolute inset-0 bg-gradient-to-br from-white/5 via-transparent to-transparent"
                        >
                        </div>

                        <!-- Content -->
                        <div
                            class="relative px-8 py-12 text-center sm:px-12 sm:py-16"
                        >
                            <!-- Main Heading -->
                            <h1
                                class="mb-6 text-4xl leading-tight font-black text-white sm:text-5xl lg:text-6xl"
                            >
                                Thank You for Your
                                <span
                                    class="block bg-gradient-to-r from-emerald-400 to-blue-500 bg-clip-text text-transparent"
                                >
                                    Application!
                                </span>
                            </h1>

                            <!-- Description -->
                            <div
                                class="mx-auto mb-10 max-w-2xl space-y-4 text-lg leading-relaxed text-gray-100 sm:text-xl"
                            >
                                <p class="opacity-90">
                                    We've received your enquiry and our
                                    admissions team is already reviewing your
                                    application.
                                </p>
                                <p class="opacity-90">
                                    One of our counselors will contact you
                                    shortly to guide you through the next steps
                                    of your admission process.
                                </p>
                                <p
                                    class="mt-6 text-xl font-semibold text-green-400 sm:text-2xl"
                                >
                                    Welcome to your journey at Graphic Era Hill
                                    University! 🎓
                                </p>
                            </div>

                            <!-- Next Steps Section -->
                            <div
                                class="rounded-2xl border border-white/20 bg-gradient-to-r from-white/10 to-white/5 p-8 backdrop-blur-sm sm:p-10"
                            >
                                <h3
                                    class="mb-6 flex items-center justify-center gap-3 text-2xl font-bold text-white sm:text-3xl"
                                >
                                    <span class="text-3xl">📋</span>
                                    What happens next?
                                </h3>

                                <div class="grid gap-4 sm:gap-6">
                                    <div
                                        class="group/item flex items-start gap-4 rounded-xl border border-white/10 bg-white/5 p-4 transition-all duration-300 hover:scale-[1.02] hover:transform hover:border-white/20 hover:bg-white/10"
                                    >
                                        <div
                                            class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-green-400 to-blue-500 text-sm font-bold text-white"
                                        >
                                            1
                                        </div>
                                        <div class="text-left">
                                            <p
                                                class="text-lg font-medium text-white"
                                            >
                                                Our counselor will call you soon
                                            </p>
                                            <p
                                                class="mt-1 text-sm text-gray-300"
                                            >
                                                Usually within 24 hours
                                            </p>
                                        </div>
                                    </div>

                                    <div
                                        class="group/item flex items-start gap-4 rounded-xl border border-white/10 bg-white/5 p-4 transition-all duration-300 hover:scale-[1.02] hover:transform hover:border-white/20 hover:bg-white/10"
                                    >
                                        <div
                                            class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-blue-400 to-purple-500 text-sm font-bold text-white"
                                        >
                                            2
                                        </div>
                                        <div class="text-left">
                                            <p
                                                class="text-lg font-medium text-white"
                                            >
                                                We'll discuss your preferences
                                            </p>
                                            <p
                                                class="mt-1 text-sm text-gray-300"
                                            >
                                                Course options and career goals
                                            </p>
                                        </div>
                                    </div>

                                    <div
                                        class="group/item flex items-start gap-4 rounded-xl border border-white/10 bg-white/5 p-4 transition-all duration-300 hover:scale-[1.02] hover:transform hover:border-white/20 hover:bg-white/10"
                                    >
                                        <div
                                            class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-purple-400 to-pink-500 text-sm font-bold text-white"
                                        >
                                            3
                                        </div>
                                        <div class="text-left">
                                            <p
                                                class="text-lg font-medium text-white"
                                            >
                                                Admission process guidance
                                            </p>
                                            <p
                                                class="mt-1 text-sm text-gray-300"
                                            >
                                                Requirements and documentation
                                            </p>
                                        </div>
                                    </div>

                                    <div
                                        class="group/item flex items-start gap-4 rounded-xl border border-white/10 bg-white/5 p-4 transition-all duration-300 hover:scale-[1.02] hover:transform hover:border-white/20 hover:bg-white/10"
                                    >
                                        <div
                                            class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-pink-400 to-red-500 text-sm font-bold text-white"
                                        >
                                            4
                                        </div>
                                        <div class="text-left">
                                            <p
                                                class="text-lg font-medium text-white"
                                            >
                                                Financial assistance
                                            </p>
                                            <p
                                                class="mt-1 text-sm text-gray-300"
                                            >
                                                Scholarships and payment options
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Landing>
    <!-- GEU Meta Code -->
    <!-- Meta Pixel Code -->
    <script type="text/javascript">
        !(function (f, b, e, v, n, t, s) {
            if (f.fbq) return;
            n = f.fbq = function () {
                n.callMethod
                    ? n.callMethod.apply(n, arguments)
                    : n.queue.push(arguments);
            };
            if (!f._fbq) f._fbq = n;
            n.push = n;
            n.loaded = !0;
            n.version = "2.0";
            n.queue = [];
            t = b.createElement(e);
            t.async = !0;
            t.src = v;
            s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s);
        })(
            window,
            document,
            "script",
            "https://connect.facebook.net/en_US/fbevents.js",
        );
        fbq("init", "248650016295389");
        fbq("track", "PageView");
    </script>
    <noscript
        ><img
            height="1"
            width="1"
            style="display:none"
            src="https://www.facebook.com/tr?id=248650016295389&ev=PageView&noscript=1"
        /></noscript
    >
    <!-- End Meta Pixel Code -->

    <!-- Event snippet for GEU_Leads conversion page -->
    <script type="text/javascript">
        function gtag_report_conversion(url) {
            var callback = function () {
                if (typeof url != "undefined") {
                    window.location = url;
                }
            };
            gtag("event", "conversion", {
                send_to: "AW-823971696/_vxmCMSb05QBEPCe84gD",
                event_callback: callback,
            });
            return false;
        }
        gtag_report_conversion();
    </script>

    <!-- Google tag (gtag.js) -->
    <script
        type="text/javascript"
        async
        src="https://www.googletagmanager.com/gtag/js?id=AW-823971696"></script>
    <script type="text/javascript">
        window.dataLayer = window.dataLayer || [];
        function gtag() {
            dataLayer.push(arguments);
        }
        gtag("js", new Date());

        gtag("config", "AW-823971696");
    </script>
</Document>
