---
const { info } = Astro.props;
---

<div class="my-20 max-w-6xl px-4 sm:mx-auto">
    <h2 class="mb-6 text-3xl font-bold tracking-tight">About the Program</h2>
    <div class="space-y-6 sm:flex-row">
        <p class="border-b-2 pb-2 font-serif text-lg font-medium italic">
            {info.headline}
        </p>
        <div class="grid grid-cols-1 gap-4 text-neutral-700 md:grid-cols-2">
            <div class="space-y-4">
                <p>{info.paragraphs[0]}</p>
                <p>{info.paragraphs[1]}</p>
            </div>
            <p>{info.paragraphs[2]}</p>
        </div>
    </div>
</div>
